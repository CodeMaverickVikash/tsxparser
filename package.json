{
  "name": "CodePilot",
  "displayName": "CodePilot",
  "description": "Full-featured JSX/TSX & TypeScript intelligence for VS Code: Go To Definition, Find Usages, Import Graph, Auto Import, Rename Refactor, Hover Docs, Breadcrumbs, and AST Explorer.",
  "version": "0.2.0",
  "engines": { "vscode": "^1.110.0" },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:typescript",
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "tsxAstTree",
          "name": "JSX/TSX Structure",
          "when": "editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/"
        }
      ]
    },
    "commands": [
      { "command": "tsxAstTree.revealRange",           "title": "Go to AST Node" },
      { "command": "tsxAstTree.findSymbol",            "title": "TSX: Find Symbol (Project-wide)", "icon": "$(search)" },
      { "command": "frontendAI.goToDefinition",        "title": "FrontendAI: Go To Definition",    "icon": "$(go-to-file)" },
      { "command": "frontendAI.findUsages",            "title": "FrontendAI: Find All Usages",     "icon": "$(references)" },
      { "command": "frontendAI.showDependencies",      "title": "FrontendAI: Show Dependencies",   "icon": "$(type-hierarchy-sub)" },
      { "command": "frontendAI.showDependents",        "title": "FrontendAI: Show Dependents",     "icon": "$(type-hierarchy-super)" },
      { "command": "frontendAI.showCircularDeps",      "title": "FrontendAI: Show Circular Dependencies", "icon": "$(warning)" },
      { "command": "frontendAI.addImport",             "title": "FrontendAI: Add Import",          "icon": "$(add)" },
      { "command": "frontendAI.renameSymbol",          "title": "FrontendAI: Rename Symbol",       "icon": "$(edit)" },
      { "command": "frontendAI.cacheStats",            "title": "FrontendAI: AST Cache Stats",     "icon": "$(database)" }
    ],
    "keybindings": [
      {
        "command": "frontendAI.goToDefinition",
        "key": "f12",
        "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/"
      },
      {
        "command": "frontendAI.findUsages",
        "key": "shift+f12",
        "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/"
      },
      {
        "command": "frontendAI.renameSymbol",
        "key": "f2",
        "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "frontendAI.goToDefinition",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "navigation@1"
        },
        {
          "command": "frontendAI.findUsages",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "navigation@2"
        },
        {
          "command": "frontendAI.renameSymbol",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "navigation@3"
        },
        {
          "command": "frontendAI.showDependencies",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "frontendAI@1"
        },
        {
          "command": "frontendAI.showDependents",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "frontendAI@2"
        },
        {
          "command": "frontendAI.addImport",
          "when": "editorTextFocus && editorLangId =~ /javascriptreact|typescriptreact|typescript|javascript/",
          "group": "frontendAI@3"
        }
      ]
    }
  },
  "scripts": {
    "compile": "webpack",
    "watch": "webpack --watch",
    "build": "webpack --mode production",
    "debug": "code --extensionDevelopmentPath=."
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
